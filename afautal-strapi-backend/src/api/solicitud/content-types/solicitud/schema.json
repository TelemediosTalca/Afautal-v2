{
  "kind": "collectionType",
  "collectionName": "solicitudes",
  "info": {
    "singularName": "solicitud",
    "pluralName": "solicitudes",
    "displayName": "Solicitud",
    "description": ""
  },
  "options": {
    "draftAndPublish": true
  },
  "attributes": {
    "rut": { "type": "string", "required": true, "unique": true, "maxLength": 9 },
    "nombre_completo": { "type": "string", "required": true },
    "fecha_nacimiento": { "type": "date", "required": true },
    "correo_electronico": { "type": "email", "required": true, "unique": true },
    "unidad_academica": { "type": "string" },
    "tipo_contrato": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::tipo-contrato.tipo-contrato"
    },
    "categoria": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::categoria.categoria"
    },
    "jerarquia": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::jerarquia.jerarquia"
    },
    "region": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::region.region"
    },
    "comuna": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::comuna.comuna"
    },
    "ciudad": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::ciudad.ciudad"
    },
    "direccion_particular": { "type": "string", "required": true },
    "telefono": { "type": "string" },
    "banco": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::banco.banco"
    },
    "tipo_cuenta": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::tipo-cuenta.tipo-cuenta"
    },
    "estado": {
      "type": "enumeration",
      "enum": ["pendiente", "aprobado", "rechazado"],
      "default": "pendiente"
    },
    "usuario": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "plugin::users-permissions.user",
      "inversedBy": "solicitud"
    },
    "es_nuevo_externo": {
      "type": "boolean",
      "default": false
    }
  }
}
